# --- Appwrite (public: sent to the browser) ---
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id

# --- Appwrite (server-only: NEVER expose) ---
# API key needs scopes: sessions.write, databases.read, databases.write,
# documents.read, documents.write
APPWRITE_API_KEY=your_server_api_key

# --- Database / collection IDs (match appwrite.json) ---
APPWRITE_DATABASE_ID=leetcode
APPWRITE_PHASES_COLLECTION_ID=phases
APPWRITE_PROBLEMS_COLLECTION_ID=problems
APPWRITE_TOKENS_COLLECTION_ID=mcp_tokens
